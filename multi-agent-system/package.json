{
  "name": "multi-agent-system",
  "version": "1.0.0",
  "description": "Multi-agent system with LangGraph orchestration",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r public dist/ 2>/dev/null || true",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "vercel-build": "tsc && mkdir -p dist/public && cp -r public/* dist/public/ 2>/dev/null || true"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.3.0",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "zod": "^3.23.0",
    "puppeteer": "^23.0.0",
    "marked": "^14.0.0",
    "html-pdf-node": "^1.0.8",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": "18.x"
  }
}
